<Window x:Class="SatisWPF.OdemeSecimWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ödeme Seçimi" Height="380" Width="420" WindowStartupLocation="CenterOwner" Background="#1A1C26">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="ÖDEME TÜRÜ" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnNakit" Content="💵 NAKİT" Height="50" Background="#27AE60" Foreground="White" FontWeight="Bold" Click="BtnNakit_Click"/>
                <Button Grid.Column="1" Content="✎" Width="40" Margin="5,0,0,0" Background="#34495E" Foreground="White" Click="Kalem_Click"/>
            </Grid>

            <Grid Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnKrediKarti" Content="💳 KREDİ KARTI" Height="50" Background="#2980B9" Foreground="White" FontWeight="Bold" Click="BtnKrediKarti_Click"/>
                <Button Grid.Column="1" Content="✎" Width="40" Margin="5,0,0,0" Background="#34495E" Foreground="White" Click="Kalem_Click"/>
            </Grid>

            <StackPanel x:Name="PnlManuel" Visibility="Collapsed" Margin="0,15,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,5,0">
                        <TextBlock Text="Nakit (₺)" Foreground="Gray" FontSize="10"/>
                        <TextBox x:Name="TxtNakitTutar" Height="35" FontSize="16" FontWeight="Bold" Text="0" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Kart (₺)" Foreground="Gray" FontSize="10"/>
                        <TextBox x:Name="TxtKartTutar" Height="35" FontSize="16" FontWeight="Bold" Text="0" VerticalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>
                <Button Content="PARÇALI ÖDEMEYİ ONAYLA" Margin="0,15,0,0" Height="40" Background="#8E44AD" Foreground="White" FontWeight="Bold" Click="BtnParcaliOnay_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>