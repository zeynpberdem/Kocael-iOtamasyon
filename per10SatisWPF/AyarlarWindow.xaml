<Window x:Class="per10SatisWPF.AyarlarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NW NEON — Ayarlar ve Raporlar"
        Height="850" Width="1300"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDark}"
        Loaded="Window_Loaded"
        Icon="favicon.ico">

    <Window.Resources>
        <!-- Tab Item Stili -->
        <Style x:Key="DarkTab" TargetType="TabItem">
            <Setter Property="Background"        Value="Transparent"/>
            <Setter Property="Foreground"        Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="FontWeight"        Value="SemiBold"/>
            <Setter Property="Padding"           Value="18,10"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd" Background="Transparent"
                                BorderBrush="Transparent" BorderThickness="0,0,0,3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid Stili -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"              Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground"              Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness"         Value="0"/>
            <Setter Property="GridLinesVisibility"     Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="RowBackground"           Value="{StaticResource BgCard}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource BgPanel}"/>
            <Setter Property="FontSize"                Value="13"/>
            <Setter Property="ColumnHeaderHeight"      Value="40"/>
            <Setter Property="RowHeight"               Value="38"/>
            <Setter Property="SelectionMode"           Value="Single"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"   Value="{StaticResource BgDark}"/>
            <Setter Property="Foreground"   Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Padding"      Value="12,0"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
        </Style>

        <!-- Input kutusu stili -->
        <Style x:Key="InputBorder" TargetType="Border">
            <Setter Property="Background"       Value="{StaticResource BgCard}"/>
            <Setter Property="CornerRadius"     Value="8"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Margin"           Value="0,0,0,10"/>
        </Style>
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Padding"          Value="10,9"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="CaretBrush"       Value="White"/>
        </Style>
        <Style x:Key="InputLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Margin"      Value="2,0,0,5"/>
        </Style>
      
    </Window.Resources>
       
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="57*"/>
            <ColumnDefinition Width="163*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="58"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- BAŞLIK -->
        <Border Grid.Row="0" Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Grid.ColumnSpan="2">
            <Grid Margin="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{StaticResource AccentBlue}" CornerRadius="8"
                            Width="36" Height="36" Margin="0,0,12,0">
                        <TextBlock Text="⚙" FontSize="18" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Foreground="White"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Ayarlar ve Raporlar" FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="NW NEON Oto Bakım Satış Sistemi"
                                   FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>
                </StackPanel>
                <Button Content="✕ Kapat" HorizontalAlignment="Right"
                        Background="Transparent" Foreground="{StaticResource TextSecondary}"
                        FontSize="13" BorderThickness="0" Cursor="Hand"
                        VerticalAlignment="Center" Click="btnKapat_Click"/>
            </Grid>
        </Border>

        <!-- SEKMELER -->
        <TabControl x:Name="tcAyarlar" SelectionChanged="tcAyarlar_SelectionChanged" 
            Grid.Row="1" Background="{StaticResource BgDark}"
            BorderThickness="0" Padding="0" Grid.ColumnSpan="2">
            <TabControl.Resources>
                <Style TargetType="TabPanel">
                    <Setter Property="Background" Value="{StaticResource BgPanel}"/>
                </Style>
            </TabControl.Resources>

            <!-- ═══ TAB 1: ÜRÜN YÖNETİMİ ══════════════════════════════ -->
            <TabItem Header="📦  Ürün Yönetimi" Style="{StaticResource DarkTab}">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="280"/>
                    </Grid.ColumnDefinitions>

                    <!-- Sol: Liste -->
                    <Grid Grid.Column="0" Margin="0,0,16,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Filtre -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="Kategori:" Foreground="{StaticResource TextSecondary}"
               FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ComboBox x:Name="cmbKategoriFiltre" Width="150" Height="36"
              Background="{StaticResource BgCard}" Foreground="{DynamicResource BgDark}"
              BorderBrush="{StaticResource BorderColor}" FontSize="13"
              SelectionChanged="cmbKategoriFiltre_Changed" Margin="0,0,20,0"/>

                            <TextBlock Text="Sıralama:" Foreground="{StaticResource TextSecondary}"
               FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ComboBox x:Name="cmbStokSiralama" Width="150" Height="36"
              Background="{StaticResource BgCard}" Foreground="{DynamicResource BgDark}"
              BorderBrush="{StaticResource BorderColor}" FontSize="13" Margin="0,0,20,0">
                                <ComboBoxItem Content="Alfabetik (A-Z)" Tag="Alfabetik" IsSelected="True"/>
                                <ComboBoxItem Content="Stok (Azalan)" Tag="StokAz"/>
                                <ComboBoxItem Content="Stok (Artan)" Tag="StokArt"/>
                            </ComboBox>

                            <Button Content="📊 Stok CSV Aktar" Height="36" Padding="15,0"
            Background="{StaticResource AccentGreen}" Foreground="White"
            FontSize="13" FontWeight="Bold" Template="{StaticResource RoundBtnTemplate}"
            Cursor="Hand" Click="btnStokExport_Click"/>
                        </StackPanel>

                        <!-- DataGrid -->
                        <Border Grid.Row="1" CornerRadius="10" ClipToBounds="True"
                                BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                            <DataGrid x:Name="dgUrunler"
                                      AutoGenerateColumns="False"
                                      SelectionChanged="dgUrunler_SelectionChanged"
                                      IsReadOnly="True" CanUserReorderColumns="False"
                                      CanUserResizeRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID"      Binding="{Binding UrunID}"   Width="50"/>
                                    <DataGridTextColumn Header="Ürün Adı" Binding="{Binding TamAdi}"  Width="*"/>
                                    <DataGridTextColumn Header="Alış ₺"  Binding="{Binding AlisFiyatiText}" Width="90"/>
                                    <DataGridTextColumn Header="Satış ₺" Binding="{Binding FiyatText}" Width="90"/>
                                    <DataGridTextColumn Header="Stok"    Binding="{Binding MevcutStok}" Width="70"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>

                    <!-- Sağ: Güncelle formu -->
                    <Border Grid.Column="1" Background="{StaticResource BgPanel}"
                            CornerRadius="12" Padding="20">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock Text="Ürün Güncelle" FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,20"/>

                            <TextBlock Text="Ürün Adı" Style="{StaticResource InputLabel}"/>
                            <Border Style="{StaticResource InputBorder}">
                                <TextBox x:Name="txtGuncelUrunAdi" Style="{StaticResource InputBox}"/>
                            </Border>

                            <TextBlock Text="Alış Fiyatı (₺)" Style="{StaticResource InputLabel}"/>
                            <Border Style="{StaticResource InputBorder}">
                                <TextBox x:Name="txtAlisFiyati" Style="{StaticResource InputBox}"/>
                            </Border>

                            <TextBlock Text="Satış Fiyatı (₺)" Style="{StaticResource InputLabel}"/>
                            <Border Style="{StaticResource InputBorder}">
                                <TextBox x:Name="txtSatisFiyati" Style="{StaticResource InputBox}"/>
                            </Border>

                            <TextBlock Text="Stok Adedi" Style="{StaticResource InputLabel}"/>
                            <Border Style="{StaticResource InputBorder}">
                                <TextBox x:Name="txtStok" Style="{StaticResource InputBox}"/>
                            </Border>

                            <TextBlock Text="Barkod" Style="{StaticResource InputLabel}"/>
                            <Border Style="{StaticResource InputBorder}">
                                <TextBox x:Name="txtBarkodGuncelle" Style="{StaticResource InputBox}"/>
                            </Border>

                            <Button Content="✓  Güncelle" Height="44" Margin="0,10,0,0"
                                    Background="{StaticResource AccentBlue}" Foreground="White"
                                    FontSize="13" FontWeight="Bold"
                                    Template="{StaticResource RoundBtnTemplate}"
                                    Cursor="Hand" Click="btnGuncelle_Click"/>

                            <Border x:Name="bdGuncelMesaj" Background="#1A3A1A" CornerRadius="8"
                                    Padding="12,8" Margin="0,10,0,0" Visibility="Collapsed">
                                <TextBlock x:Name="lblGuncelMesaj" Foreground="{StaticResource AccentGreen}"
                                           FontSize="12" TextWrapping="Wrap"/>
                            </Border>
                            <Border Background="#331A1A" BorderBrush="{StaticResource AccentRed}" BorderThickness="1" 
        CornerRadius="8" Padding="12" Margin="0,20,0,10">
                                <TextBlock Text="⚠️ DİKKAT: Marka veya Ürün Silebilmeniz için, o öğenin bulunduğu bütün Satış ve Sepet kayıtlarının silinmesi gerekmektedir!" 
               Foreground="{StaticResource AccentRed}" FontSize="11" TextWrapping="Wrap" FontWeight="SemiBold"/>
                            </Border>

                            <Button Content="🗑️  Seçili Ürünü Sil" Height="38" Margin="0,0,0,15"
        Background="{StaticResource AccentRed}" Foreground="White"
        FontSize="13" FontWeight="Bold" Template="{StaticResource RoundBtnTemplate}"
        Cursor="Hand" Click="btnUrunSil_Click"/>

                            <TextBlock Text="Marka Sil" Style="{StaticResource InputLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="{StaticResource BgCard}" CornerRadius="8" 
            BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,0,8,0">
                                    <ComboBox x:Name="cmbMarkaSil" Background="Transparent" Foreground="{DynamicResource BgDark}" 
                  BorderThickness="0" Padding="10,8" FontSize="13"/>
                                </Border>
                                <Button Grid.Column="1" Content="🗑️ Sil" Width="70"
            Background="{StaticResource AccentRed}" Foreground="White"
            FontSize="13" FontWeight="Bold" Template="{StaticResource RoundBtnTemplate}"
            Cursor="Hand" Click="btnMarkaSil_Click"/>
                            </Grid>
                        </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══ TAB 2: YENİ ÜRÜN EKLE ══════════════════════════════ -->
            <TabItem Header="➕  Yeni Ürün" Style="{StaticResource DarkTab}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="40,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Sol kolon -->
                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <TextBlock Text="Ürün Bilgileri" FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,20"/>

                            <TextBlock Text="Ürün Adı" Style="{StaticResource InputLabel}"/>
                            <Border Style="{StaticResource InputBorder}">
                                <TextBox x:Name="txtYeniUrunAdi" Style="{StaticResource InputBox}"/>
                            </Border>

                            <TextBlock Text="Kategori" Style="{StaticResource InputLabel}"/>
                            <Border Background="{StaticResource BgCard}" CornerRadius="8"
                                    BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,0,0,10">
                                <ComboBox x:Name="cmbYeniTur" Background="Transparent"
                                          Foreground="{DynamicResource BgDark}"
                                          BorderThickness="0" Padding="10,8" FontSize="13"/>
                            </Border>

                            <TextBlock Text="Marka" Style="{StaticResource InputLabel}"/>
                            <Border Background="{StaticResource BgCard}" CornerRadius="8"
                                    BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,0,0,10">
                                <ComboBox x:Name="cmbYeniMarka" Background="Transparent"
                                          Foreground="{DynamicResource BgDark}"
                                          BorderThickness="0" Padding="10,8" FontSize="13"/>
                            </Border>

                            <!-- Yeni Marka Ekleme Alanı -->
                            <Border Background="#1A1E2D" CornerRadius="8"
                                    BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                                    Padding="12" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="YENİ MARKA EKLE"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource InputBorder}" Margin="0,0,8,0">
                                            <TextBox x:Name="txtYeniMarka" Style="{StaticResource InputBox}"
                                                     ToolTip="Yeni marka adını yazın"/>
                                        </Border>
                                        <Button Grid.Column="1" Content="+ Ekle" Height="38" Padding="14,0"
                                                Background="{StaticResource AccentBlue}" Foreground="White"
                                                FontSize="12" FontWeight="Bold"
                                                Template="{StaticResource RoundBtnTemplate}"
                                                Cursor="Hand" Click="btnYeniMarkaEkle_Click"/>
                                    </Grid>
                                    <Border x:Name="bdMarkaMesaj" Background="#1A3A1A" CornerRadius="6"
                                            Padding="10,6" Margin="0,4,0,0" Visibility="Collapsed">
                                        <TextBlock x:Name="lblMarkaMesaj" Foreground="{StaticResource AccentGreen}"
                                                   FontSize="11" TextWrapping="Wrap"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Barkod (opsiyonel)" Style="{StaticResource InputLabel}"/>
                            <Border Style="{StaticResource InputBorder}">
                                <TextBox x:Name="txtYeniBarkod" Style="{StaticResource InputBox}"/>
                            </Border>
                        </StackPanel>

                        <!-- Sağ kolon -->
                        <StackPanel Grid.Column="1" Margin="20,0,0,0">
                            <TextBlock Text="Fiyat ve Stok" FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,20"/>

                            <TextBlock Text="Alış Fiyatı (₺)" Style="{StaticResource InputLabel}"/>
                            <Border Style="{StaticResource InputBorder}">
                                <TextBox x:Name="txtYeniAlis" Style="{StaticResource InputBox}"/>
                            </Border>

                            <TextBlock Text="Satış Fiyatı (₺)" Style="{StaticResource InputLabel}"/>
                            <Border Style="{StaticResource InputBorder}">
                                <TextBox x:Name="txtYeniSatis" Style="{StaticResource InputBox}"/>
                            </Border>

                            <TextBlock Text="Başlangıç Stoğu" Style="{StaticResource InputLabel}"/>
                            <Border Style="{StaticResource InputBorder}">
                                <TextBox x:Name="txtYeniStok" Style="{StaticResource InputBox}"/>
                            </Border>

                            <TextBlock Text="Kritik Stok Seviyesi" Style="{StaticResource InputLabel}"/>
                            <Border Style="{StaticResource InputBorder}">
                                <TextBox x:Name="txtYeniKritikStok" Style="{StaticResource InputBox}" Text="5"/>
                            </Border>

                            <Button Content="➕  Ürünü Kaydet" Height="48" Margin="0,16,0,0"
                                    Background="{StaticResource AccentGreen}" Foreground="White"
                                    FontSize="14" FontWeight="Bold"
                                    Template="{StaticResource RoundBtnTemplate}"
                                    Cursor="Hand" Click="btnYeniUrunEkle_Click"/>

                            <Border x:Name="bdEkleMesaj" Background="#1A3A1A" CornerRadius="8"
                                    Padding="12,8" Margin="0,12,0,0" Visibility="Collapsed">
                                <TextBlock x:Name="lblEkleMesaj" Foreground="{StaticResource AccentGreen}"
                                           FontSize="12" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="🤖 Akıllı Asistan" Style="{StaticResource DarkTab}" Height="40" VerticalAlignment="Bottom">
                <Grid Margin="40,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="150"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,20">

                        <Border Background="#2D1F24" BorderBrush="#EF4444" BorderThickness="2" CornerRadius="12" Margin="10"
Cursor="Hand" MouseDown="BorderKritikStok_MouseDown">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="🔴 Kritik Stok" FontSize="18" Foreground="#EF4444" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="txtKritikStokAnalizi" Text="Veriler Yükleniyor..." Foreground="White" TextWrapping="Wrap" FontSize="14" Margin="10"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#2D2A1F" BorderBrush="#F59E0B" BorderThickness="2" CornerRadius="12" Margin="10" 
MouseDown="BorderHareketsizUrunler_MouseDown" Cursor="Hand">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="🟡 Hareketsiz Ürünler" FontSize="18" Foreground="#F59E0B" FontWeight="Bold" HorizontalAlignment="Center"/>
                               
                                <TextBlock x:Name="txtHareketsizUrunAnalizi" Text="Veriler Yükleniyor..." Foreground="White" TextWrapping="Wrap" FontSize="14" Margin="10"/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="bdTelegramKart" Background="#1F2D24" BorderBrush="#10B981" BorderThickness="2" CornerRadius="12" Margin="10">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock x:Name="txtTelegramDurumBaslik" Text="🟢 Telegram Asistanı" FontSize="18" Foreground="#10B981" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="txtTelegramDurumAlt" Text="Kontrol ediliyor..." FontSize="14" Foreground="White" Margin="0,5,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                    </UniformGrid>
                    <Grid Grid.Row="1" Margin="10,0,10,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="12" Padding="15" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock x:Name="lblListeBasligi" Text="📋 İncelenecek Ürünler" Foreground="White" FontSize="18" FontWeight="Bold" Margin="10,0,0,0"/>

                                <ListBox Background="#252526" Foreground="White" BorderThickness="0" Height="250" x:Name="lstUrunler" SelectionChanged="lstUrunler_SelectionChanged">
                                    <ListBoxItem Padding="10">
                                        <StackPanel Orientation="Horizontal">
                                            
                                        </StackPanel>
                                    </ListBoxItem>
                                    <ListBoxItem Padding="10">
                                        <StackPanel Orientation="Horizontal">
                                            
                                        </StackPanel>
                                    </ListBoxItem>
                                </ListBox>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#252526" CornerRadius="12" Padding="15" Margin="0,0,0,10" BorderBrush="#deff9a" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="💡 Asistanın Tavsiyesi" FontSize="16" Foreground="#deff9a" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="txtAsistanYorumu" TextWrapping="Wrap" FontSize="14" Foreground="White" LineHeight="20"
                       Text="Vidalı mil grubunda 3 aydır hareket yok. Bu sermayeyi buraya bağlamak yerine hızlı giden Oto Şampuanı ürününe yatırman daha mantıklı."/>
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Row="1">
                                <Button Content="⚡ Kampanya Yap (Fiyatı Düşür)" Background="#F59E0B" Foreground="Black" FontWeight="Bold" Height="40" Margin="0,0,0,5" BorderThickness="0" Cursor="Hand" Click="btnKampanyaYap_Click">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>

                                <Button x:Name="btnTelegramBildir" Content="📱 Telegram'a Bildir" Background="#0088cc" Foreground="White" FontWeight="Bold" Height="40" BorderThickness="0" Click="Button_Click" IsEnabled="False"/>
                                
                            </StackPanel>
                        </Grid>

                    </Grid>

                    <!-- En Çok Satan 5 Ürün -->
                    <Border Grid.Row="2" Background="#1A1E2D" CornerRadius="12"
                            Padding="14,10" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="🏆  Son 7 Günün En Çok Satan 5 Ürünü"
                                       FontSize="13" FontWeight="Bold" Foreground="#F59E0B" Margin="0,0,0,8"/>
                            <WrapPanel x:Name="pnlEnCokSatan"/>
                        </StackPanel>
                    </Border>

                </Grid>
            </TabItem>
            <!-- ═══ TAB 3: SATIŞ RAPORU ═════════════════════════════════ -->
            <TabItem Header="📊  Satış Raporu" Style="{StaticResource DarkTab}">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Filtre Bölümü -->
                    <Border Grid.Row="0" Background="{StaticResource BgPanel}"
                            CornerRadius="12" Padding="20,16" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Başlangıç:" Foreground="{StaticResource TextSecondary}"
                                       FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <DatePicker x:Name="dpBaslangic" Width="150" Margin="0,0,20,0"
                                        Background="{StaticResource BgCard}"
                                        Foreground="{DynamicResource BgDark}"
                                        FontSize="13"/>
                            <TextBlock Text="Bitiş:" Foreground="{StaticResource TextSecondary}"
                                       FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <DatePicker x:Name="dpBitis" Width="150" Margin="0,0,20,0"
                                        Background="{StaticResource BgCard}"
                                        Foreground="{DynamicResource BgDark}"
                                        FontSize="13"/>
                            <Button Content="🔍  Rapor Getir" Height="38" Padding="20,0"
                                    Background="{DynamicResource AccentGreen}" Foreground="White"
                                    FontSize="13" FontWeight="Bold"
                                    Template="{StaticResource RoundBtnTemplate}"
                                    Cursor="Hand" Click="btnRaporGetir_Click" Margin="0,0,8,0"/>
                            <Button Content="📥  Excel'e Aktar ve SİL" Height="38" Padding="20,0"
                                    Background="{DynamicResource AccentOrange}" Foreground="White"
                                    FontSize="13" FontWeight="Bold"
                                    Template="{StaticResource RoundBtnTemplate}"
                                    Cursor="Hand" Click="btnSatisExport_Click"/>
                            <Button Content="🗑️  Seçili Sepeti İptal Et" Height="38" Padding="15,0" Margin="8,0,0,0"
        Background="#D32F2F" Foreground="White"
        FontSize="13" FontWeight="Bold"
        Template="{StaticResource RoundBtnTemplate}"
        Cursor="Hand" Click="btnSepetIptal_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Özet Kartlar -->
                    <Grid Grid.Row="1" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{StaticResource BgPanel}" CornerRadius="12" Padding="15" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="💰 CİRO" Foreground="{StaticResource TextSecondary}" FontSize="11" FontWeight="Bold"/>
                                <TextBlock x:Name="lblCiro" Text="—" Foreground="{StaticResource AccentGreen}" FontSize="20" FontWeight="Bold" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="{StaticResource BgPanel}" CornerRadius="12" Padding="15" Margin="4,0">
                            <StackPanel>
                                <TextBlock Text="📈 KAR" Foreground="{StaticResource TextSecondary}" FontSize="11" FontWeight="Bold"/>
                                <TextBlock x:Name="lblKar" Text="—" Foreground="{StaticResource AccentBlue}" FontSize="20" FontWeight="Bold" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="{StaticResource BgPanel}" CornerRadius="12" Padding="15" Margin="4,0">
                            <StackPanel>
                                <TextBlock Text="💵 NAKİT" Foreground="{StaticResource TextSecondary}" FontSize="11" FontWeight="Bold"/>
                                <TextBlock x:Name="lblSatisNakit" Text="—" Foreground="#28a745" FontSize="20" FontWeight="Bold" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="3" Background="{StaticResource BgPanel}" CornerRadius="12" Padding="15" Margin="4,0">
                            <StackPanel>
                                <TextBlock Text="💳 KREDİ" Foreground="{StaticResource TextSecondary}" FontSize="11" FontWeight="Bold"/>
                                <TextBlock x:Name="lblSatisKredi" Text="—" Foreground="#007acc" FontSize="20" FontWeight="Bold" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4" Background="{StaticResource BgPanel}" CornerRadius="12" Padding="15" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="🛒 İŞLEM" Foreground="{StaticResource TextSecondary}" FontSize="11" FontWeight="Bold"/>
                                <TextBlock x:Name="lblIslem" Text="—" Foreground="{StaticResource AccentOrange}" FontSize="20" FontWeight="Bold" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Sepet Detay Listesi -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" CornerRadius="10" ClipToBounds="True"
                                BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                                Margin="0,0,8,0">
                            <DataGrid x:Name="dgSepetler" AutoGenerateColumns="False"
                                      IsReadOnly="True" CanUserReorderColumns="False"
                                      CanUserResizeRows="False"
                                      SelectionChanged="dgSepetler_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Sepet #"   Binding="{Binding SepetID}"  Width="60"/>
                                    <DataGridTextColumn Header="Net Tutar" Binding="{Binding Toplam}"   Width="*"/>
                                    <DataGridTextColumn Header="İndirim"   Binding="{Binding Indirim}"  Width="75"/>
                                    <DataGridTextColumn Header="Ödeme"     Binding="{Binding Odeme}"    Width="90"/>
                                    <DataGridTextColumn Header="Tarih"     Binding="{Binding Tarih}"    Width="135"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <Border Grid.Column="1" CornerRadius="10" ClipToBounds="True"
                                BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                                Margin="8,0,0,0">
                            <DataGrid x:Name="dgSepetDetay" AutoGenerateColumns="False"
                                      IsReadOnly="True" CanUserReorderColumns="False"
                                      CanUserResizeRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Ürün"    Binding="{Binding UrunAdi}"   Width="*"/>
                                    <DataGridTextColumn Header="Adet"    Binding="{Binding Miktar}"    Width="60"/>
                                    <DataGridTextColumn Header="Fiyat"   Binding="{Binding Fiyat}"     Width="90"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ═══ TAB 4: GRAFİKLER ════════════════════════════════════ -->
            <TabItem Header="📉  Grafikler" Style="{StaticResource DarkTab}">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <DatePicker x:Name="dpGrafBaslangic" Width="150" Margin="0,0,10,0" Background="{StaticResource BgCard}" FontSize="13"/>
                        <DatePicker x:Name="dpGrafBitis" Width="150" Margin="0,0,16,0" Background="{StaticResource BgCard}" FontSize="13"/>
                        <Button Content="🏆  En Çok Satan" Height="38" Padding="16,0" Margin="0,0,8,0" Background="{StaticResource AccentBlue}" Foreground="White" FontSize="13" Template="{StaticResource RoundBtnTemplate}" Cursor="Hand" Click="btnEnCokSatan_Click"/>
                        <Button Content="💰  En Çok Kar" Height="38" Padding="16,0" Margin="0,0,8,0" Background="{StaticResource AccentGreen}" Foreground="White" FontSize="13" Template="{StaticResource RoundBtnTemplate}" Cursor="Hand" Click="btnEnCokKar_Click"/>
                    </StackPanel>

                    <Border Grid.Row="1" Background="{StaticResource BgPanel}" CornerRadius="12" Padding="20">
                        <Grid>
                            <TextBlock x:Name="lblGrafikBos" Text="Yukarıdan bir grafik türü seçin" Foreground="{StaticResource TextSecondary}" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <ScrollViewer x:Name="svGrafik" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Visibility="Collapsed">
                                <Canvas x:Name="cnvGrafik" Height="320"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Background="{StaticResource BgPanel}" CornerRadius="12" Padding="16,12" Margin="0,16,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="Rapor Şifresini Güncelle:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" Margin="0,0,12,0"/>
                            <Border Style="{StaticResource InputBorder}" Margin="0,0,12,0" Padding="0">
                                <TextBox x:Name="txtYeniRaporPin" Style="{StaticResource InputBox}" MaxLength="6" Width="120" HorizontalContentAlignment="Center"/>
                            </Border>
                            <Button Content="🔑 Şifreyi Kaydet" Height="38" Background="{StaticResource AccentOrange}" Foreground="White" FontSize="13" FontWeight="Bold" Template="{StaticResource RoundBtnTemplate}" Cursor="Hand" Click="btnRaporPinKaydet_Click" Padding="16,0"/>
                        </StackPanel>
                    </Border>

                </Grid>
            </TabItem>

            <!-- ═══ TAB 5: YIKAMA RAPORU ════════════════════════════════ -->
            <TabItem Header="🚿  Yıkama Raporu" Style="{StaticResource DarkTab}">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Filtre -->
                    <Border Grid.Row="0" Background="{StaticResource BgPanel}"
                            CornerRadius="12" Padding="20,16" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Başlangıç:" Foreground="{StaticResource TextSecondary}"
                                       FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <DatePicker x:Name="dpYikamaBaslangic" Width="150" Margin="0,0,20,0"
                                        Background="{StaticResource BgCard}" FontSize="13"/>
                            <TextBlock Text="Bitiş:" Foreground="{StaticResource TextSecondary}"
                                       FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <DatePicker x:Name="dpYikamaBitis" Width="150" Margin="0,0,20,0"
                                        Background="{StaticResource BgCard}" FontSize="13"/>
                            <Button Content="🔍  Rapor Getir" Height="38" Padding="20,0"
                                    Background="{DynamicResource AccentGreen}" Foreground="White"
                                    FontSize="13" FontWeight="Bold"
                                    Template="{StaticResource RoundBtnTemplate}"
                                    Cursor="Hand" Click="btnYikamaRaporGetir_Click" Margin="0,0,8,0"/>
                            <Button Content="📥  Excel'e Aktar ve SİL" Height="38" Padding="20,0"
                                    Background="{DynamicResource AccentOrange}" Foreground="White"
                                    FontSize="13" FontWeight="Bold"
                                    Template="{StaticResource RoundBtnTemplate}"
                                    Cursor="Hand" Click="btnYikamaExport_Click"/>
                            <Button Content="🗑️  Seçili Yıkamayı İptal Et" Height="38" Padding="15,0" Margin="8,0,0,0"
Background="#D32F2F" Foreground="White"
FontSize="13" FontWeight="Bold"
Template="{StaticResource RoundBtnTemplate}"
Cursor="Hand" Click="btnYikamaIptal_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Özet Kart -->
                    <Grid Grid.Row="1" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{StaticResource BgPanel}" CornerRadius="12" Padding="15" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="🚿 GELİR" Foreground="{StaticResource TextSecondary}" FontSize="11" FontWeight="Bold"/>
                                <TextBlock x:Name="lblYikamaToplam" Text="—" Foreground="{StaticResource AccentOrange}" FontSize="20" FontWeight="Bold" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="{StaticResource BgPanel}" CornerRadius="12" Padding="15" Margin="4,0">
                            <StackPanel>
                                <TextBlock Text="💵 NAKİT" Foreground="{StaticResource TextSecondary}" FontSize="11" FontWeight="Bold"/>
                                <TextBlock x:Name="lblYikamaNakit" Text="—" Foreground="#28a745" FontSize="20" FontWeight="Bold" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="{StaticResource BgPanel}" CornerRadius="12" Padding="15" Margin="4,0">
                            <StackPanel>
                                <TextBlock Text="💳 KREDİ" Foreground="{StaticResource TextSecondary}" FontSize="11" FontWeight="Bold"/>
                                <TextBlock x:Name="lblYikamaKredi" Text="—" Foreground="#007acc" FontSize="20" FontWeight="Bold" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="3" Background="{StaticResource BgPanel}" CornerRadius="12" Padding="15" Margin="4,0">
                            <StackPanel>
                                <TextBlock Text="🔢 SAYI" Foreground="{StaticResource TextSecondary}" FontSize="11" FontWeight="Bold"/>
                                <TextBlock x:Name="lblYikamaSayisi" Text="—" Foreground="{StaticResource AccentBlue}" FontSize="20" FontWeight="Bold" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4" Background="{StaticResource BgPanel}" CornerRadius="12" Padding="15" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="📊 ORTALAMA" Foreground="{StaticResource TextSecondary}" FontSize="11" FontWeight="Bold"/>
                                <TextBlock x:Name="lblYikamaOrtalama" Text="—" Foreground="{StaticResource AccentGreen}" FontSize="20" FontWeight="Bold" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    <!-- Liste -->
                    <Border Grid.Row="2" CornerRadius="10" ClipToBounds="True"
                            BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                        <DataGrid x:Name="dgYikamalar" AutoGenerateColumns="False"
                                  IsReadOnly="True" CanUserReorderColumns="False"
                                  CanUserResizeRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#"       Binding="{Binding YikamaID}"  Width="60"/>
                                <DataGridTextColumn Header="Tutar"   Binding="{Binding Tutar}"     Width="100"/>
                                <DataGridTextColumn Header="Ödeme"   Binding="{Binding Odeme}"     Width="120"/>
                                <DataGridTextColumn Header="Tarih"   Binding="{Binding Tarih}"     Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="🏷️  Kategori İşlemleri" Style="{StaticResource DarkTab}">
                <Grid Margin="40,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Text="Yeni Kategori Ekle" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,20"/>

                        <TextBlock Text="Kategori Adı" Style="{StaticResource InputLabel}"/>
                        <Border Style="{StaticResource InputBorder}">
                            <TextBox x:Name="txtYeniKategoriAdi" Style="{StaticResource InputBox}"/>
                        </Border>

                        <Button Content="➕  Kategori Ekle" Height="44" Margin="0,10,0,0"
                    Background="{StaticResource AccentGreen}" Foreground="White"
                    FontSize="13" FontWeight="Bold" Template="{StaticResource RoundBtnTemplate}"
                    Cursor="Hand" Click="btnKategoriEkle_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="20,0,0,0">
                        <TextBlock Text="Kategori Sil" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10"/>

                        <Border Background="#331A1A" BorderBrush="{StaticResource AccentRed}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,15">
                            <TextBlock Text="⚠️ DİKKAT: Yalnızca kendisine ait hiçbir ürün bulunmayan (boş) kategoriler silinebilir!" 
                           Foreground="{StaticResource AccentRed}" FontSize="12" TextWrapping="Wrap" FontWeight="SemiBold"/>
                        </Border>

                        <TextBlock Text="Silinecek Kategori" Style="{StaticResource InputLabel}"/>
                        <Border Background="{StaticResource BgCard}" CornerRadius="8" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,0,0,10">
                            <ComboBox x:Name="cmbKategoriSil" Background="Transparent" Foreground="{DynamicResource BgDark}" BorderThickness="0" Padding="10,8" FontSize="13"/>
                        </Border>

                        <Button Content="🗑️  Kategoriyi Sil" Height="44" Margin="0,10,0,0"
                    Background="{StaticResource AccentRed}" Foreground="White"
                    FontSize="13" FontWeight="Bold" Template="{StaticResource RoundBtnTemplate}"
                    Cursor="Hand" Click="btnKategoriSil_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="🔒  Güvenlik" Style="{StaticResource DarkTab}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="40,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" HorizontalAlignment="Stretch" Margin="0,0,30,0">
                            <TextBlock Text="Ana Giriş Bilgileri (Login)" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,20"/>

                            <TextBlock Text="Yeni Kullanıcı Adı" Style="{StaticResource InputLabel}"/>
                            <Border Style="{StaticResource InputBorder}">
                                <TextBox x:Name="txtYeniAdminID" Style="{StaticResource InputBox}"/>
                            </Border>

                            <TextBlock Text="Yeni Şifre" Style="{StaticResource InputLabel}"/>
                            <Border Style="{StaticResource InputBorder}">
                                <TextBox x:Name="txtYeniAdminSifre" Style="{StaticResource InputBox}"/>
                            </Border>

                            <Button Content="💾  Giriş Bilgilerini Kaydet" Height="44" Margin="0,20,0,0"
                        Background="{StaticResource AccentBlue}" Foreground="White"
                        FontSize="13" FontWeight="Bold" Template="{StaticResource RoundBtnTemplate}"
                        Cursor="Hand" Click="btnGirisBilgiKaydet_Click"/>
                        </StackPanel>

                        <Border Grid.Column="1" BorderBrush="{StaticResource BorderColor}" BorderThickness="1,0,0,0" Margin="0,10" VerticalAlignment="Stretch"/>

                        <StackPanel Grid.Column="2" HorizontalAlignment="Stretch" Margin="30,0,0,0">
                            <TextBlock Text="Telegram Bildirim Ayarları" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                            <TextBlock Text="Raporların gönderileceği dükkan sahibinin Telegram Bot ve ID bilgileri." Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,0,0,20"/>

                            <TextBlock Text="Telegram Chat ID" Style="{StaticResource InputLabel}"/>
                            <Border Style="{StaticResource InputBorder}">
                                <TextBox x:Name="txtTelegramChatId" Style="{StaticResource InputBox}"/>
                            </Border>

                            <TextBlock Text="Telegram Bot Token" Style="{StaticResource InputLabel}" Margin="0,5,0,0"/>
                            <Border Style="{StaticResource InputBorder}">
                                <TextBox x:Name="txtTelegramToken" Style="{StaticResource InputBox}"/>
                            </Border>

                            <Button Content="⚙️  Telegram Ayarlarını Güncelle" Height="44" Margin="0,5,0,0" Background="#2563EB" Foreground="White" FontSize="13" FontWeight="Bold" Template="{StaticResource RoundBtnTemplate}" Cursor="Hand" Click="btnTelegramKaydet_Click"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

        </TabControl>
        <!-- Kampanya Yap Popup -->
        <Border x:Name="bdKampanyaPopup" Grid.RowSpan="2" Grid.ColumnSpan="2"
                Width="400" Height="210"
                Background="{StaticResource BgPanel}"
                BorderBrush="#F59E0B" BorderThickness="2" CornerRadius="12"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Panel.ZIndex="999" Visibility="Collapsed" Padding="24">
            <StackPanel>
                <TextBlock Text="⚡ Kampanya Fiyatı Belirle" FontSize="15" FontWeight="Bold"
                           Foreground="#F59E0B" Margin="0,0,0,4"/>
                <TextBlock x:Name="lblKampanyaUrunAdi" Foreground="{StaticResource TextSecondary}"
                           FontSize="12" TextWrapping="Wrap" Margin="0,0,0,14"/>
                <TextBlock Text="Yeni Satış Fiyatı (₺)" Foreground="{StaticResource TextSecondary}"
                           FontSize="12" Margin="0,0,0,5"/>
                <Border Background="{StaticResource BgDark}" CornerRadius="8"
                        BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,0,0,16">
                    <TextBox x:Name="txtKampanyaFiyat" Background="Transparent"
                             Foreground="White" BorderThickness="0"
                             Padding="12,10" FontSize="18" FontWeight="Bold"
                             CaretBrush="White" KeyDown="txtKampanyaFiyat_KeyDown"/>
                </Border>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="İptal" Background="Transparent"
                            Foreground="{StaticResource TextSecondary}" FontSize="13"
                            FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                            Click="btnKampanyaIptal_Click" Margin="0,0,6,0"/>
                    <Button Grid.Column="1" Content="✓ Fiyatı Güncelle" Height="38"
                            Background="#F59E0B" Foreground="Black" FontSize="13" FontWeight="Bold"
                            Template="{StaticResource RoundBtnTemplate}" Cursor="Hand"
                            Click="btnKampanyaOnayla_Click" Margin="6,0,0,0"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border x:Name="gridPinKilit" Grid.RowSpan="2" Grid.ColumnSpan="2"
                Width="300" Height="170" 
                Background="{StaticResource BgPanel}" 
                BorderBrush="{StaticResource AccentBlue}" BorderThickness="2" CornerRadius="4"
                HorizontalAlignment="Center" VerticalAlignment="Center" 
                Panel.ZIndex="1000" Visibility="Collapsed" Padding="20">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="🔒 Rapor Şifresi" FontSize="15" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <PasswordBox x:Name="txtPinGiris" Background="{StaticResource BgDark}" Foreground="White" 
                             BorderBrush="{StaticResource BorderColor}" BorderThickness="1" 
                             Padding="10" FontSize="18" HorizontalContentAlignment="Center" 
                             PasswordChar="●" MaxLength="6" Margin="0,0,0,15"
                             KeyDown="txtPinGiris_KeyDown"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="İptal" Background="Transparent" Foreground="{StaticResource TextSecondary}" FontSize="13" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="btnPinIptal_Click" Margin="0,0,5,0"/>
                    <Button Grid.Column="1" Content="Aç" Height="34" Background="{StaticResource AccentBlue}" Foreground="White" FontSize="13" FontWeight="Bold" Template="{StaticResource RoundBtnTemplate}" Cursor="Hand" Click="btnPinOnay_Click" Margin="5,0,0,0"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
    
</Window>
